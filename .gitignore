# Root .gitignore for BrickYard Pro

# Node modules
**/node_modules/
node_modules/

# Environment files and secrets
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
.env
.env.local

# Next.js build output
**/.next/
.next/

# Node-packer or other logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Production build and caches
**/dist/
**/build/
.cache/
.parcel-cache/

# System / OS files
.DS_Store
Thumbs.db
