// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────
// AUTH & USERS
// ──────────────────────────────────────────

enum Role {
  CUSTOMER
  SUPER_ADMIN
  INVENTORY_MANAGER
  LOGISTICS_MANAGER
  ACCOUNTS
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String?
  passwordHash  String
  role          Role      @default(CUSTOMER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses     Address[]
  orders        Order[]
  loyaltyPoints Int       @default(0)
  referralCode  String?   @unique
  referredBy    String?

  @@map("users")
}

model Address {
  id          String   @id @default(uuid())
  userId      String
  label       String   // "Home", "Site A", etc.
  line1       String
  line2       String?
  city        String
  state       String
  pincode     String
  lat         Float?
  lng         Float?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  orders      Order[]

  @@map("addresses")
}

// ──────────────────────────────────────────
// PRODUCTS & CATEGORIES
// ──────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@map("categories")
}

enum StockStatus {
  IN_STOCK
  MADE_TO_ORDER
  OUT_OF_STOCK
}

model Product {
  id              String      @id @default(uuid())
  categoryId      String
  name            String
  slug            String      @unique
  description     String?
  unit            String      // "brick", "bag", "ton", "sq_ft"
  basePrice       Float       // price per unit
  weight          Float       // kg per unit (for vehicle selection)
  stockStatus     StockStatus @default(IN_STOCK)
  stockQuantity   Int?        // null = unlimited
  imageUrls       String[]    @default([])
  specifications  Json?       // { dimensions, strength, color, etc. }
  isActive        Boolean     @default(true)
  isFeatured      Boolean     @default(false)
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  category        Category    @relation(fields: [categoryId], references: [id])
  pricingTiers    PricingTier[]
  orderItems      OrderItem[]

  @@map("products")
}

model PricingTier {
  id          String   @id @default(uuid())
  productId   String
  minQty      Int      // minimum quantity for this tier
  maxQty      Int?     // null = unlimited
  pricePerUnit Float   // price at this tier
  createdAt   DateTime @default(now())

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("pricing_tiers")
}

model Discount {
  id          String    @id @default(uuid())
  name        String
  type        String    // "percentage" | "flat"
  value       Float
  startsAt    DateTime
  endsAt      DateTime
  productIds  String[]  @default([])  // empty = all products
  minOrderVal Float?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@map("discounts")
}

// ──────────────────────────────────────────
// DELIVERY ZONES
// ──────────────────────────────────────────

model DeliveryZone {
  id              String   @id @default(uuid())
  name            String
  type            String   // "pincode" | "radius" | "polygon"
  pincodes        String[] @default([])
  centerLat       Float?
  centerLng       Float?
  radiusKm        Float?
  polygonPoints   Json?    // array of {lat, lng} for polygon zones
  flatCharge      Float    // fixed delivery charge for this zone
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("delivery_zones")
}

model PerKmPricing {
  id              String   @id @default(uuid())
  vehicleTypeId   String
  ratePerKm       Float
  baseFare        Float    // minimum charge
  minimumKm       Float    @default(0)
  overnightCharge Float    @default(0)
  updatedAt       DateTime @updatedAt

  vehicleType     VehicleType @relation(fields: [vehicleTypeId], references: [id])

  @@map("per_km_pricing")
}

// ──────────────────────────────────────────
// VEHICLES & LABOUR
// ──────────────────────────────────────────

model VehicleType {
  id              String   @id @default(uuid())
  name            String   // "Tata Ace", "6-Wheeler", "10-Wheeler"
  maxWeightKg     Float
  maxVolumeCbm    Float?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  perKmPricing    PerKmPricing[]
  orders          Order[]

  @@map("vehicle_types")
}

model LabourSettings {
  id                  String   @id @default(uuid())
  ratePerThousand     Float    // ₹ per 1000 bricks loaded+unloaded
  minimumLabourCount  Int      @default(2)
  bricksPerLabourer   Int      @default(1000) // bricks one labourer handles per day
  foodChargePerPerson Float    @default(150)   // ₹ per labourer per day
  overtimeRatePerHr   Float    @default(100)
  standardHoursPerDay Int      @default(8)
  updatedAt           DateTime @updatedAt

  @@map("labour_settings")
}

// ──────────────────────────────────────────
// ORDERS
// ──────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  MANUFACTURING
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
}

model Order {
  id                String        @id @default(uuid())
  orderNumber       String        @unique // e.g. BY-2024-00123
  userId            String?
  customerName      String
  customerPhone     String
  customerEmail     String?
  
  // Delivery
  addressId         String?
  deliveryLine1     String
  deliveryLine2     String?
  deliveryCity      String
  deliveryPincode   String
  deliveryLat       Float?
  deliveryLng       Float?
  
  // Pricing breakdown
  materialCost      Float
  transportCost     Float
  labourCost        Float
  labourFoodCost    Float         @default(0)
  gstAmount         Float
  discountAmount    Float         @default(0)
  totalAmount       Float
  
  // Config snapshot
  vehicleTypeId     String?
  labourCount       Int           @default(0)
  includeLabourFood Boolean       @default(false)
  deliveryDistanceKm Float?
  zoneId            String?
  
  // Notes
  notes             String?
  deliveryDate      DateTime?
  
  // Status
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  paymentId         String?       // Razorpay payment ID
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User?         @relation(fields: [userId], references: [id])
  address           Address?      @relation(fields: [addressId], references: [id])
  vehicleType       VehicleType?  @relation(fields: [vehicleTypeId], references: [id])
  items             OrderItem[]
  statusHistory     OrderStatusHistory[]

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  productId   String
  productName String  // snapshot
  unit        String
  quantity    Int
  unitPrice   Float   // price at time of order
  subtotal    Float

  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}

// ──────────────────────────────────────────
// SYSTEM CONFIG
// ──────────────────────────────────────────

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_config")
}
